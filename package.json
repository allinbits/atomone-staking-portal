{
  "name": "@atomone/atomone-staking",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.20.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test:e2e:serve": "serve -s dist -l 8080",
    "test:e2e": "npx playwright install && playwright test",
    "test:components": "npx playwright install && playwright test -c playwright-ct.config.ts",
    "test:components:debug": "npx playwright install && playwright test -c playwright-ct.config.ts --debug",
    "test:unit": "vitest run --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agoose77/markdown-it-mermaid": "^1.1.0",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmostation/cosmos-client": "^0.0.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/vue-query": "^5.97.0",
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-istanbul": "^4.1.4",
    "@vueuse/core": "^14.2.1",
    "bech32": "^2.0.0",
    "bignumber.js": "^10.0.2",
    "cosmjs-types": "^0.11.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "markdown-it": "^14.1.1",
    "markdown-it-github-alert": "^1.0.6",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@atomone/atomone-types": "^1.0.3",
    "@cosmjs/stargate": "^0.38.1",
    "@cosmjs/tendermint-rpc": "^0.38.1",
    "@keplr-wallet/types": "^0.13.20",
    "@playwright/experimental-ct-vue": "1.59.1",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.15",
    "@vitest/ui": "^4.1.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "~10.8.0",
    "happy-dom": "^20.8.9",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "mitt": "^3.0.1",
    "mobx": "^6.15.0",
    "mobx-vue-lite": "^0.4.3",
    "npm-run-all2": "^8.0.4",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
